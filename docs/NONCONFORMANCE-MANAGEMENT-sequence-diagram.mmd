%%{init: {'theme': 'base', 'themeVariables': {'actorBkg': '#ad1457', 'actorTextColor': '#fff', 'actorBorder': '#880e4f', 'signalColor': '#333', 'noteBkgColor': '#fff8e1', 'noteBorderColor': '#ED8B00'}}}%%

sequenceDiagram
    autonumber

    participant OP as Operator/QC Analyst<br/>(END_USER)
    participant API as Spring Boot API<br/>(NonconformanceService)
    participant FL as Flowable Engine<br/>(ncProcess)
    participant DB as PostgreSQL<br/>(Database)
    participant QR as QA Reviewer<br/>(QA_REVIEWER)
    participant CO as NC Owner<br/>(OWNER)
    participant QA as QA Approver<br/>(QA_APPROVER)
    participant NS as Notification<br/>Service
    participant DV as Deviation<br/>(Cross-Module)
    participant CP as CAPA<br/>(Cross-Module)
    participant SQ as Supplier Quality<br/>(Cross-Module)
    participant CC as Change Control<br/>(Cross-Module)
    participant RM as Risk Management<br/>(Cross-Module)

    rect rgb(232, 244, 248)
        Note over OP,NS: Step 1: Identify Nonconformance (IDENTIFIED)
        OP->>API: POST /api/v1/nonconformances<br/>{title, description, ncType,<br/>productName, productCode,<br/>batchNumber, batchSize,<br/>quantityAffected, unitOfMeasure,<br/>detectedLocation, stageDetected,<br/>ownerId, departmentId, plantSiteId,<br/>supplierId (if supplier-related)}
        API->>DB: Generate NC number (NC-2026-001)
        API->>DB: INSERT nonconformances (status=IDENTIFIED)
        API->>FL: startProcess("ncProcess", vars)<br/>{recordId, ncNumber, ownerId,<br/>ncType, productCode, batchNumber,<br/>supplierId}
        FL-->>FL: Create initialReview task<br/>(candidateGroups: QA_REVIEWER)
        API->>DB: Workflow: "Identified" COMPLETED
        API->>DB: Workflow: "Initial Review" CURRENT
        API->>DB: Audit trail: CREATED
        NS->>DB: INSERT notification (TASK_ASSIGNED)
        NS-->>QR: "NC Reported" notification
        API-->>OP: 201 Created (NonconformanceResponse)

        opt Immediate Material Hold
            OP->>API: PATCH /api/v1/nonconformances/{id}/hold<br/>{holdStatus: "ON_HOLD",<br/>holdLocation: "Quarantine Area B",<br/>holdInitiatedDate: now()}
            API->>DB: UPDATE nonconformances<br/>(holdStatus=ON_HOLD)
            API->>DB: Audit trail: MATERIAL_HELD
            NS-->>QR: "Material Placed on Hold" alert
        end
    end

    rect rgb(255, 248, 225)
        Note over QR,NS: Step 2: Initial Review & Classification (IDENTIFIED -> UNDER_REVIEW)
        QR->>API: GET /api/v1/tasks/inbox
        API->>FL: Query tasks for QA_REVIEWER
        FL-->>API: initialReview task for NC-2026-001
        API-->>QR: Task list

        QR->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)

        QR->>API: PUT /api/v1/nonconformances/{id}<br/>{classification: "CRITICAL/MAJOR/MINOR",<br/>priority: adjusted}

        alt Valid NC - Proceed
            QR->>API: PATCH /api/v1/nonconformances/{id}/status<br/>{status: "UNDER_REVIEW"}
            API->>FL: completeTask("initialReview",<br/>{reviewDecision: "VALID"})
            FL-->>FL: Create investigation task<br/>(assignee: ownerId)
            API->>DB: Status = UNDER_REVIEW
            API->>DB: Workflow: "Initial Review" COMPLETED
            API->>DB: Workflow: "Investigation" CURRENT
            API->>DB: Audit trail: CLASSIFIED
        else Not a Valid NC
            QR->>API: PATCH /api/v1/nonconformances/{id}/status<br/>{status: "VOID"}
            API->>FL: completeTask("initialReview",<br/>{reviewDecision: "VOID"})

            opt Release Hold if applicable
                QR->>API: PATCH /api/v1/nonconformances/{id}/hold<br/>{holdStatus: "RELEASED",<br/>holdReleasedDate: now()}
                API->>DB: holdStatus = RELEASED
            end

            FL-->>FL: Process ends (Voided)
            API->>DB: Audit trail: NC_VOIDED
        end
        API-->>QR: 200 OK
    end

    rect rgb(232, 244, 248)
        Note over CO,NS: Step 3: Investigation (UNDER_REVIEW -> INVESTIGATION_COMPLETE)
        CO->>API: PUT /api/v1/nonconformances/{id}<br/>{investigation findings documented}

        Note over CO: Investigate root cause:<br/>- Material defect?<br/>- Process failure?<br/>- Equipment issue?<br/>- Human error?<br/>- Supplier quality issue?

        opt Cross-Module: Link to Existing Deviation
            CO->>API: PUT /api/v1/nonconformances/{id}<br/>{deviationId: existingDeviationId}
            API->>DB: UPDATE nonconformances<br/>SET deviation_id
            API->>DB: Audit trail: DEVIATION_LINKED
        end

        opt Cross-Module: Create New Deviation
            Note over DV: NC investigation reveals<br/>process deviation
            CO->>API: POST /api/v1/deviations<br/>{title: "Deviation from NC investigation",<br/>sourceArea: nc.detectedLocation,<br/>type: "PROCESS/MATERIAL"}
            API->>DB: INSERT deviations
            API->>DB: UPDATE nonconformances<br/>SET deviation_id = newDeviationId
            Note over DV: Deviation follows its own<br/>workflow lifecycle
        end

        opt Cross-Module: Supplier Notification
            Note over SQ: For supplier-related NCs<br/>(supplierId is set)
            CO->>API: Notify supplier of NC<br/>and request SCAR (Supplier<br/>Corrective Action Request)
            API->>DB: Audit trail: SUPPLIER_NOTIFIED
            NS-->>SQ: Supplier notification sent

            CO->>API: PUT /api/v1/suppliers/{supplierId}<br/>{qualityScore: adjusted downward}
            API->>DB: UPDATE supplier scores
        end

        CO->>API: PATCH /api/v1/nonconformances/{id}/status<br/>{status: "INVESTIGATION_COMPLETE"}
        API->>FL: completeTask("investigation")
        FL-->>FL: Create dispositionReview task<br/>(candidateGroups: QA_APPROVER)
        API->>DB: Status = INVESTIGATION_COMPLETE
        API->>DB: Workflow: "Investigation" COMPLETED
        API->>DB: Workflow: "Disposition" CURRENT
        API->>DB: Audit trail: INVESTIGATION_COMPLETED
        API-->>CO: 200 OK
    end

    rect rgb(255, 248, 225)
        Note over QA,NS: Step 4: Disposition Decision (INVESTIGATION_COMPLETE -> DISPOSITION)
        QA->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)

        Note over QA: Review investigation and<br/>determine material disposition
        Note over QA: E-Signature Dialog opens

        QA->>API: PATCH /api/v1/nonconformances/{id}/disposition<br/>{dispositionDecision: "USE_AS_IS/<br/>REWORK/REPROCESS/RETURN_TO_SUPPLIER/<br/>SCRAP/REJECT",<br/>dispositionJustification: "...",<br/>capaRequired: true/false}<br/>(with e-signature)
        API->>DB: UPDATE nonconformances<br/>(dispositionDecision, justification,<br/>dispositionApprovedBy, dispositionDate)
        API->>DB: Audit trail: DISPOSITION_DECIDED

        alt Disposition: RETURN_TO_SUPPLIER
            Note over SQ: Cross-Module: Supplier return
            API->>DB: Notify supplier for material return
            NS-->>SQ: "Material Return: NC-2026-001"

            opt Update supplier performance
                QA->>API: PUT /api/v1/suppliers/{supplierId}<br/>{qualityScore: further adjusted}
                API->>DB: UPDATE supplier scores
            end
        end

        alt Disposition: REWORK/REPROCESS
            Note over CC: Cross-Module: May require<br/>Change Control if non-standard
            opt Non-Standard Rework
                QA->>API: POST /api/v1/change-requests<br/>{title: "Non-standard rework approval",<br/>sourceType: "NONCONFORMANCE",<br/>sourceId: ncId}
            end
        end

        QA->>API: PATCH /api/v1/nonconformances/{id}/status<br/>{status: "DISPOSITION"}
        API->>FL: completeTask("dispositionReview",<br/>{capaRequired: true/false,<br/>dispositionDecision: "..."})
        FL-->>FL: capaGateway evaluates capaRequired

        alt CAPA Required
            FL-->>FL: Create capaInitiation task<br/>(candidateGroups: QA_REVIEWER)
            API->>DB: Status = CAPA_PENDING
            API->>DB: Workflow: "Disposition" COMPLETED
            API->>DB: Workflow: "CAPA Initiation" CURRENT
        else No CAPA Required
            FL-->>FL: Create closureReview task<br/>(candidateGroups: QA_APPROVER)
            API->>DB: Status = PENDING_CLOSURE
            API->>DB: Workflow: "Disposition" COMPLETED
            API->>DB: Workflow: "Closure Review" CURRENT
        end
        API-->>QA: 200 OK
    end

    rect rgb(243, 229, 245)
        Note over QR,NS: Step 4a: CAPA Initiation [Conditional] (CAPA_PENDING)
        Note over CP: Cross-Module: Create linked CAPA

        QR->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)

        QR->>API: POST /api/v1/capas<br/>{sourceType: "NONCONFORMANCE",<br/>sourceId: ncId,<br/>title: nc.title,<br/>description: nc.description}
        API->>DB: INSERT capas (linked to NC)
        API->>DB: UPDATE nonconformances<br/>SET capa_id = newCapaId
        API->>DB: Audit trail: CAPA_INITIATED_FROM_NC
        Note over CP: CAPA follows its own<br/>workflow lifecycle

        opt Cross-Module: Risk Register Update
            Note over RM: Recurring NC pattern<br/>requires risk assessment
            QR->>API: POST /api/v1/risks/registers/{registerId}/assessments<br/>{hazardDescription: nc.description,<br/>riskCategory: nc.ncType}
            API->>DB: INSERT risk_assessments
        end

        QR->>API: PATCH /api/v1/nonconformances/{id}/status<br/>{status: "PENDING_CLOSURE"}
        API->>FL: completeTask("capaInitiation")
        FL-->>FL: Create closureReview task<br/>(candidateGroups: QA_APPROVER)
        API->>DB: Status = PENDING_CLOSURE
        API->>DB: Workflow: "CAPA Initiation" COMPLETED
        API->>DB: Workflow: "Closure Review" CURRENT
        API-->>QR: 200 OK
    end

    rect rgb(255, 248, 225)
        Note over QA,NS: Step 5: Final Review & Closure (PENDING_CLOSURE -> CLOSED)
        QA->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)

        Note over QA: Review all investigation,<br/>disposition, hold release,<br/>and CAPA linkage
        Note over QA: E-Signature Dialog opens

        opt Release Material Hold
            QA->>API: PATCH /api/v1/nonconformances/{id}/hold<br/>{holdStatus: "RELEASED",<br/>holdReleasedDate: now(),<br/>holdReleasedById}
            API->>DB: holdStatus = RELEASED
            API->>DB: Audit trail: HOLD_RELEASED
        end

        QA->>API: PATCH /api/v1/nonconformances/{id}/status<br/>{status: "CLOSED"}<br/>(with e-signature)

        API->>API: validateClosureRules()<br/>- Investigation complete?<br/>- Disposition decided?<br/>- Hold released (if applicable)?<br/>- CAPA linked (if required)?

        API->>DB: closedDate = now()
        API->>FL: completeTask("closureReview")
        FL-->>FL: notifyClosed service task fires
        FL->>NS: notificationDelegate<br/>"NC Closed: NC-2026-001"
        NS->>DB: INSERT notification (STATUS_CHANGE)
        NS-->>OP: "NC Closed" notification
        NS-->>CO: "NC Closed" notification

        API->>DB: Status = CLOSED
        API->>DB: Workflow: "Closure Review" COMPLETED
        API->>DB: Workflow: "Closed" COMPLETED
        API->>DB: Audit trail: STATUS_CHANGED -> CLOSED
        FL-->>FL: Process ends

        API-->>QA: 200 OK
    end
