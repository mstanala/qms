%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#2C5F7C', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1B3A4B', 'lineColor': '#333', 'secondaryColor': '#ED8B00', 'tertiaryColor': '#f5f7fa'}}}%%

flowchart TD
    Start([Start Event<br/>Deviation Reported]) --> qaReview

    subgraph REVIEW_PHASE ["Step 1: QA Review & Classification"]
        qaReview[/"<b>QA Review & Classification</b><br/>Candidate: QA_REVIEWER<br/>Form: deviation-classify"/]
    end

    qaReview --> reviewGW{{"Review<br/>Decision?"}}

    reviewGW -->|REJECTED| rejectedEnd([Rejected End<br/>Deviation Rejected])
    reviewGW -->|CLASSIFIED| notifyInvestigator

    subgraph NOTIFY_PHASE ["Notification"]
        notifyInvestigator["Notify Investigator<br/>(notificationDelegate)<br/>TASK_ASSIGNED to assignedToId"]
    end

    notifyInvestigator --> investigation

    subgraph INVESTIGATION_PHASE ["Step 2: Root Cause Investigation"]
        investigation[/"<b>Root Cause Investigation</b><br/>Assignee: assignedToId<br/>Form: deviation-investigate<br/>Due: targetClosureDate"/]
        investigationTimer>"Boundary Timer<br/>P25D (25 days)<br/>Non-interrupting"] -.- investigation
        investigationTimer --> escalateOverdue["Escalation Delegate<br/>INVESTIGATION_OVERDUE"]
    end

    investigation --> impactAssessment

    subgraph IMPACT_PHASE ["Step 3: Impact Assessment"]
        impactAssessment[/"<b>Impact Assessment</b><br/>Candidate: QA_REVIEWER, QA_APPROVER<br/>Form: deviation-impact<br/>4-Dimension Matrix"/]
    end

    impactAssessment --> disposition

    subgraph DISPOSITION_PHASE ["Step 4: Disposition Decision"]
        disposition[/"<b>Disposition Decision</b><br/>Candidate: QA_APPROVER<br/>Form: deviation-disposition<br/>E-Signature Required"/]
    end

    disposition --> capaGW{{"CAPA<br/>Required?"}}

    capaGW -->|"capaRequired<br/>= true"| capaInitiation
    capaGW -->|"capaRequired<br/>= false"| pendingClosure

    subgraph CAPA_PHASE ["Step 5a: CAPA Initiation (Conditional)"]
        capaInitiation[/"<b>Initiate CAPA</b><br/>Candidate: QA_REVIEWER, OWNER<br/>Form: deviation-capa"/]
    end

    capaInitiation --> pendingClosure

    subgraph CLOSURE_PHASE ["Step 6: Final Review & Closure"]
        pendingClosure[/"<b>QA Final Review & Closure</b><br/>Candidate: QA_APPROVER<br/>Form: deviation-close<br/>E-Signature Required"/]
        pendingClosure --> notifyClosed["Notify Closure<br/>(notificationDelegate)<br/>Send to: Reported By"]
    end

    notifyClosed --> closedEnd([End Event<br/>Deviation Closed])

    %% Styling
    classDef startEnd fill:#2C5F7C,stroke:#1B3A4B,color:#fff,stroke-width:2px
    classDef userTask fill:#fff,stroke:#2C5F7C,color:#333,stroke-width:2px
    classDef gateway fill:#ED8B00,stroke:#D4760A,color:#fff,stroke-width:2px
    classDef serviceTask fill:#f5f7fa,stroke:#667085,color:#333,stroke-width:1px
    classDef timer fill:#fff3e0,stroke:#ED8B00,color:#333,stroke-width:1px
    classDef rejected fill:#c62828,stroke:#b71c1c,color:#fff,stroke-width:2px

    class Start,closedEnd startEnd
    class rejectedEnd rejected
    class qaReview,investigation,impactAssessment,disposition,capaInitiation,pendingClosure userTask
    class reviewGW,capaGW gateway
    class notifyInvestigator,notifyClosed,escalateOverdue serviceTask
    class investigationTimer timer
