%%{init: {'theme': 'base', 'themeVariables': {'actorBkg': '#2C5F7C', 'actorTextColor': '#fff', 'actorBorder': '#1B3A4B', 'signalColor': '#333', 'noteBkgColor': '#fff8e1', 'noteBorderColor': '#ED8B00'}}}%%

sequenceDiagram
    autonumber

    participant PE as Production Engineer<br/>(END_USER)
    participant API as Spring Boot API<br/>(ChangeRequestService)
    participant FL as Flowable Engine<br/>(changeControlProcess)
    participant DB as PostgreSQL<br/>(Database)
    participant CO as Change Owner<br/>(OWNER)
    participant QR as QA Reviewer<br/>(QA_REVIEWER)
    participant RA as RA Reviewer<br/>(REVIEWER)
    participant QA as QA Approver<br/>(QA_APPROVER)
    participant NS as Notification<br/>Service

    rect rgb(232, 244, 248)
        Note over PE,NS: Step 1: Create Change Request (DRAFT)
        PE->>API: POST /api/v1/change-requests<br/>{title, description, justification, type,<br/>category, classification, priority,<br/>changeOwnerId, departmentId, plantSiteId...}
        API->>DB: Generate CC number (CC-2026-001)
        API->>DB: INSERT change_requests (status=DRAFT)
        API->>FL: startProcess("changeControlProcess", vars)
        FL-->>FL: Create submitChange task<br/>(assignee: changeOwnerId)
        API->>DB: Record workflow step: "Draft" CURRENT
        API->>DB: Audit trail: CREATED
        API->>NS: Notify Change Owner:<br/>"Change Control Assigned"
        NS->>DB: INSERT notification (TASK_ASSIGNED)
        API-->>PE: 201 Created
    end

    rect rgb(255, 248, 225)
        Note over CO,NS: Step 2: Submit Change Request (DRAFT -> SUBMITTED)
        CO->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "SUBMITTED"}
        API->>FL: completeTask("submitChange")
        FL-->>FL: Create impactAssessment task<br/>(assignee: changeOwnerId)
        API->>DB: Status = SUBMITTED
        API->>DB: Workflow: "Submit Change" COMPLETED
        API->>DB: Workflow: "Impact Assessment" CURRENT
        API->>DB: Audit trail: STATUS_CHANGED
        API-->>CO: 200 OK
    end

    rect rgb(232, 244, 248)
        Note over CO,NS: Step 3: Impact Assessment (SUBMITTED -> QA_REVIEW)
        CO->>API: POST /api/v1/change-requests/{id}/impact-assessment<br/>{productQuality: HIGH, patientSafety: MEDIUM,<br/>regulatoryCompliance: HIGH, validationStatus: HIGH,<br/>documentation: MEDIUM, training: MEDIUM,<br/>supplierQualification: NO_IMPACT, stability: HIGH,<br/>overallRiskLevel: HIGH, assessmentSummary: "..."}
        API->>DB: INSERT/UPDATE change_impact_assessments
        API->>DB: Audit trail: IMPACT_ASSESSMENT_SUBMITTED

        CO->>API: POST /api/v1/change-requests/{id}/affected-documents<br/>{documentNumber, documentTitle, action: REVISE}
        API->>DB: INSERT change_affected_documents

        CO->>API: POST /api/v1/change-requests/{id}/affected-products<br/>{productName, productCode, markets, impactDescription}
        API->>DB: INSERT change_affected_products

        CO->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "QA_REVIEW"}
        API->>FL: completeTask("impactAssessment")
        FL-->>FL: Create qaReview task<br/>(assignee: qaReviewerId)
        API->>DB: Status = QA_REVIEW
        API->>DB: Workflow: "Impact Assessment" COMPLETED
        API->>DB: Workflow: "QA Review" CURRENT
        API-->>CO: 200 OK
    end

    rect rgb(255, 248, 225)
        Note over QR,NS: Step 4: QA Review (QA_REVIEW -> RA_REVIEW or PENDING_APPROVAL)
        QR->>API: GET /api/v1/tasks/inbox
        API->>FL: Query tasks for QA_REVIEWER
        FL-->>API: qaReview task for CC-2026-001
        API-->>QR: Task list

        QR->>API: POST /api/v1/change-requests/{id}/approvals<br/>{approverId, role: "QA Head", approvalOrder: 1}
        API->>DB: INSERT change_approvals (decision=PENDING)

        QR->>API: POST /api/v1/change-requests/{id}/approvals<br/>{approverId, role: "Plant Director", approvalOrder: 2}
        API->>DB: INSERT change_approvals (decision=PENDING)

        alt Regulatory Filing Required
            QR->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "RA_REVIEW"}
            API->>FL: completeTask("qaReview",<br/>{regulatoryFilingRequired: true})
            FL-->>FL: raGateway -> raReview task<br/>(candidate: QA_REVIEWER)
            API->>DB: Status = RA_REVIEW
            API->>DB: Workflow: "QA Review" COMPLETED
            API->>DB: Workflow: "RA Review" CURRENT
        else No Regulatory Filing
            QR->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "PENDING_APPROVAL"}
            API->>FL: completeTask("qaReview",<br/>{regulatoryFilingRequired: false})
            FL-->>FL: raGateway -> pendingApproval task<br/>(candidate: QA_APPROVER, APPROVER)
            API->>DB: Status = PENDING_APPROVAL
        end
    end

    rect rgb(243, 229, 245)
        Note over RA,NS: Step 4a: RA Review [Conditional] (RA_REVIEW -> PENDING_APPROVAL)
        RA->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)

        RA->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "PENDING_APPROVAL"}
        API->>FL: completeTask("raReview")
        FL-->>FL: Create pendingApproval task<br/>(candidate: QA_APPROVER, APPROVER)
        API->>DB: Status = PENDING_APPROVAL
        API->>DB: Workflow: "RA Review" COMPLETED
        API->>DB: Workflow: "Pending Approval" CURRENT
        API-->>RA: 200 OK
    end

    rect rgb(232, 244, 248)
        Note over QA,NS: Step 5: Approval (PENDING_APPROVAL -> APPROVED/REJECTED)
        QA->>API: GET /api/v1/tasks/inbox
        API-->>QA: pendingApproval task

        loop For each approver
            QA->>API: PATCH /api/v1/change-requests/{id}/approvals/{approvalId}<br/>{decision: "APPROVED", comments: "..."}
            API->>DB: UPDATE change_approvals (decision, decisionDate)
            API->>DB: Audit trail: APPROVAL_DECISION
        end

        alt All Approved
            Note over QA: E-Signature Dialog opens
            QA->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "APPROVED"}<br/>(with e-signature: "I confirm the approve change")
            API->>FL: completeTask("pendingApproval",<br/>{approvalDecision: "APPROVED"})
            FL-->>FL: approvalGateway -> implementation task<br/>(assignee: changeOwnerId)<br/>+ Start 30-day boundary timer
            API->>DB: Status = APPROVED -> IMPLEMENTATION
            API->>DB: Workflow: "Approval" COMPLETED ("Approved")
            API->>DB: Workflow: "Implementation" CURRENT
        else Rejected
            QA->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "REJECTED", comments: "reason"}
            API->>FL: completeCurrentTask({approvalDecision: "REJECTED"})
            FL-->>FL: approvalGateway -> rejectedEnd
            API->>DB: Status = REJECTED
            Note over QA,NS: Process ends
        end
    end

    rect rgb(255, 248, 225)
        Note over CO,NS: Step 6: Implementation (IMPLEMENTATION -> VERIFICATION)
        CO->>API: POST /api/v1/change-requests/{id}/implementation-tasks<br/>{title, description, assignedToId, dueDate}
        API->>DB: INSERT change_implementation_tasks (NOT_STARTED)

        loop For each task
            CO->>API: PUT /api/v1/change-requests/{id}/implementation-tasks/{taskId}<br/>{status: "IN_PROGRESS"}
            API->>DB: UPDATE task status

            CO->>API: PUT /api/v1/change-requests/{id}/implementation-tasks/{taskId}<br/>{status: "COMPLETED", completedDate: now()}
            API->>DB: UPDATE task status + completedDate
        end

        opt After 30 days (boundary timer)
            FL->>NS: escalationDelegate<br/>IMPLEMENTATION_OVERDUE
            NS-->>CO: Overdue escalation notification
        end

        CO->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "VERIFICATION"}
        API->>FL: completeTask("implementation")
        API->>DB: actualImplementationDate = now()
        API->>DB: Status = VERIFICATION
        API->>DB: Workflow: "Implementation" COMPLETED
        API->>DB: Workflow: "Verification" CURRENT
        API-->>CO: 200 OK
    end

    rect rgb(232, 244, 248)
        Note over QR,NS: Step 7: Verification (VERIFICATION -> EFFECTIVENESS_CHECK)
        QR->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)
        Note over QR: Verify all tasks, docs, training complete
        Note over QR: E-Signature Dialog opens
        QR->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "EFFECTIVENESS_CHECK"}<br/>(with e-signature)
        API->>FL: completeTask("verification")
        FL-->>FL: Create effectivenessCheck task<br/>(candidate: QA_APPROVER)
        API->>DB: Status = EFFECTIVENESS_CHECK
        API->>DB: Workflow: "Verification" COMPLETED
        API->>DB: Workflow: "Effectiveness Check" CURRENT
        API-->>QR: 200 OK
    end

    rect rgb(255, 248, 225)
        Note over QA,NS: Step 8: Effectiveness Check & Closure (EFFECTIVENESS_CHECK -> CLOSED)
        QA->>API: POST /api/v1/tasks/{taskId}/claim
        API->>FL: claimTask(taskId, userId)

        QA->>API: POST /api/v1/change-requests/{id}/effectiveness-review<br/>{reviewDate, overallEffective: true,<br/>summary: "All criteria met",<br/>criteria: [{criterion, met, evidence}...]}
        API->>DB: INSERT change_effectiveness_reviews
        API->>DB: INSERT change_effectiveness_criteria
        API->>DB: Audit trail: EFFECTIVENESS_REVIEW_SUBMITTED

        Note over QA: E-Signature Dialog opens
        QA->>API: PATCH /api/v1/change-requests/{id}/status<br/>{status: "CLOSED"}<br/>(with e-signature)

        API->>API: validateClosureRules()<br/>- All tasks COMPLETED?<br/>- All approvals obtained?<br/>- All training complete?

        API->>DB: closedDate = now()
        API->>FL: completeTask("effectivenessCheck")
        FL-->>FL: notifyClosed service task fires
        FL->>NS: notificationDelegate<br/>"Change Control Closed: CC-2026-001"
        NS->>DB: INSERT notification (STATUS_CHANGE)
        NS-->>PE: "Change Control Closed" notification

        API->>DB: Status = CLOSED
        API->>DB: Workflow: "Effectiveness Check" COMPLETED
        API->>DB: Workflow: "Closed" COMPLETED
        API->>DB: Audit trail: STATUS_CHANGED -> CLOSED
        FL-->>FL: Process ends

        API-->>QA: 200 OK
    end
