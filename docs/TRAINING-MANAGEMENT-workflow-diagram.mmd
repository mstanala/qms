%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#00695c', 'primaryTextColor': '#fff', 'primaryBorderColor': '#004d40', 'lineColor': '#333', 'secondaryColor': '#ED8B00', 'tertiaryColor': '#f5f7fa'}}}%%

flowchart TD
    Start([Start Event<br/>Training Assigned]) --> completeTraining

    subgraph TRIGGER_PHASE ["Cross-Module Triggers"]
        docTrigger["Document Effective<br/>(SOP Revision)"]
        ccTrigger["Change Control<br/>(Implementation Phase)"]
        devTrigger["Deviation Closure<br/>(Retraining Required)"]
        capaTrigger["CAPA Action<br/>(Preventive Training)"]
        manualTrigger["Manual Assignment<br/>(Training Coordinator)"]
    end

    docTrigger --> Start
    ccTrigger --> Start
    devTrigger --> Start
    capaTrigger --> Start
    manualTrigger --> Start

    subgraph TRAINING_PHASE ["Step 1: Complete Training"]
        completeTraining[/"<b>Complete Training</b><br/>Assignee: traineeId<br/>Form: training-complete<br/>Due: dueDate"/]
        overdueTimer>"Boundary Timer<br/>dueDate<br/>Non-interrupting"] -.- completeTraining
        overdueTimer --> escalateOverdue["Escalation Delegate<br/>TRAINING_OVERDUE<br/>Notify: Trainee + Coordinator"]
    end

    completeTraining --> resultGW{{"Training<br/>Result?"}}

    resultGW -->|"trainingResult<br/>= PASSED"| verifyTraining
    resultGW -->|"trainingResult<br/>= FAILED<br/>(attempts remaining)"| completeTraining
    resultGW -->|"trainingResult<br/>= FAILED<br/>(max attempts)"| failedEnd

    subgraph VERIFY_PHASE ["Step 2: Verify Training Effectiveness"]
        verifyTraining[/"<b>Verify Training</b><br/>Candidate: QA_APPROVER,<br/>TRAINING_COORDINATOR<br/>Form: training-verify"/]
    end

    verifyTraining --> notifyComplete

    subgraph COMPLETE_PHASE ["Step 3: Notify & Update Source"]
        notifyComplete["Notify Completion<br/>(notificationDelegate)<br/>TRAINING_COMPLETED<br/>to: Trainee, Coordinator"]
        notifyComplete --> updateSource["Update Source Record<br/>(sourceUpdateDelegate)<br/>Mark training complete<br/>on triggering module"]
    end

    updateSource --> completedEnd([End Event<br/>Training Verified])

    failedEnd([Failed End<br/>Training Failed -<br/>Escalation Required])

    subgraph RETRAINING_PHASE ["Periodic Retraining"]
        retrainingTimer>"Boundary Timer<br/>validityMonths<br/>Non-interrupting"] -.- completedEnd
        retrainingTimer --> retrainingReminder["Retraining Reminder<br/>(notificationDelegate)<br/>RETRAINING_DUE"]
    end

    %% Styling
    classDef startEnd fill:#00695c,stroke:#004d40,color:#fff,stroke-width:2px
    classDef userTask fill:#fff,stroke:#00695c,color:#333,stroke-width:2px
    classDef gateway fill:#ED8B00,stroke:#D4760A,color:#fff,stroke-width:2px
    classDef serviceTask fill:#f5f7fa,stroke:#667085,color:#333,stroke-width:1px
    classDef timer fill:#fff3e0,stroke:#ED8B00,color:#333,stroke-width:1px
    classDef trigger fill:#e8f5e9,stroke:#43a047,color:#333,stroke-width:1px
    classDef failed fill:#c62828,stroke:#b71c1c,color:#fff,stroke-width:2px

    class Start,completedEnd startEnd
    class failedEnd failed
    class completeTraining,verifyTraining userTask
    class resultGW gateway
    class notifyComplete,updateSource,escalateOverdue,retrainingReminder serviceTask
    class overdueTimer,retrainingTimer timer
    class docTrigger,ccTrigger,devTrigger,capaTrigger,manualTrigger trigger
