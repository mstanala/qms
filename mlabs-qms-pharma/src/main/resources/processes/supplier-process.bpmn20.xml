<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://qmspharma.com/supplier"
             id="supplierDefinitions">

    <process id="supplierQualificationProcess" name="Supplier Qualification Process" isExecutable="true">

        <!-- Process Variables:
             recordId, supplierNumber, supplierName, qualificationOwnerId,
             supplierType, category -->

        <startEvent id="start" name="Supplier Qualification Initiated"/>

        <sequenceFlow id="flow-start-docReview" sourceRef="start" targetRef="documentReview"/>

        <!-- Step 1: Document Review -->
        <userTask id="documentReview" name="Document Review"
                  flowable:candidateGroups="QA_REVIEWER"
                  flowable:formKey="supplier-document-review">
            <documentation>Review supplier documentation, certificates, and questionnaire responses</documentation>
        </userTask>

        <sequenceFlow id="flow-docReview-docGW" sourceRef="documentReview" targetRef="docGateway"/>

        <!-- Gateway: Document Review Decision -->
        <exclusiveGateway id="docGateway" name="Document Review Decision"/>

        <sequenceFlow id="flow-doc-rejected" sourceRef="docGateway" targetRef="endRejected">
            <conditionExpression>${documentDecision == 'REJECTED'}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-doc-audit" sourceRef="docGateway" targetRef="supplierAudit">
            <conditionExpression>${documentDecision == 'AUDIT_REQUIRED'}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-doc-noAudit" sourceRef="docGateway" targetRef="qualificationApproval">
            <conditionExpression>${documentDecision == 'NO_AUDIT'}</conditionExpression>
        </sequenceFlow>

        <!-- Step 2: Supplier Audit (if required) -->
        <userTask id="supplierAudit" name="Supplier Audit"
                  flowable:candidateGroups="QA_REVIEWER,AUDITOR"
                  flowable:formKey="supplier-audit">
            <documentation>Conduct on-site or remote GMP audit of supplier facility</documentation>
        </userTask>

        <sequenceFlow id="flow-audit-auditGW" sourceRef="supplierAudit" targetRef="auditGateway"/>

        <!-- Gateway: Audit Result -->
        <exclusiveGateway id="auditGateway" name="Audit Result Decision"/>

        <sequenceFlow id="flow-audit-passed" sourceRef="auditGateway" targetRef="qualificationApproval">
            <conditionExpression>${auditResult == 'PASSED'}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-audit-failed" sourceRef="auditGateway" targetRef="supplierCorrectiveAction">
            <conditionExpression>${auditResult == 'FAILED'}</conditionExpression>
        </sequenceFlow>

        <!-- Step 3: Corrective Action (if audit failed) -->
        <userTask id="supplierCorrectiveAction" name="Supplier Corrective Action"
                  flowable:assignee="${qualificationOwnerId}"
                  flowable:formKey="supplier-corrective-action">
            <documentation>Track corrective actions required after failed supplier audit</documentation>
        </userTask>

        <sequenceFlow id="flow-corrective-approval" sourceRef="supplierCorrectiveAction" targetRef="qualificationApproval"/>

        <!-- Step 4: Qualification Approval -->
        <userTask id="qualificationApproval" name="Qualification Approval"
                  flowable:candidateGroups="QA_APPROVER"
                  flowable:formKey="supplier-qualification-approval">
            <documentation>Approve or reject supplier qualification based on assessment and audit results</documentation>
        </userTask>

        <sequenceFlow id="flow-approval-approvalGW" sourceRef="qualificationApproval" targetRef="approvalGateway"/>

        <!-- Gateway: Approval Decision -->
        <exclusiveGateway id="approvalGateway" name="Qualification Decision"/>

        <sequenceFlow id="flow-approved" sourceRef="approvalGateway" targetRef="endApproved">
            <conditionExpression>${approvalDecision == 'APPROVED'}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-approval-rejected" sourceRef="approvalGateway" targetRef="endRejected">
            <conditionExpression>${approvalDecision == 'REJECTED'}</conditionExpression>
        </sequenceFlow>

        <!-- End Events -->
        <endEvent id="endApproved" name="Supplier Qualified"/>
        <endEvent id="endRejected" name="Supplier Rejected"/>

    </process>
</definitions>
